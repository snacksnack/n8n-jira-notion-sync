    {
      "parameters": {
        "jsCode": "const error = $input.first().json;\nreturn [{\n  json: {\n    message: `⚠️ Jira↔Notion sync failed\\nWorkflow: ${error.workflow?.name || 'RC1 Sync'}\\nError: ${error.execution?.error?.message || 'Unknown error'}\\nTime: ${new Date().toISOString()}\\nExecution: ${error.execution?.id}`\n  }\n}];"
      },
