      "id": "96293df6-5382-49f4-926a-67d678abea08",
      "name": "Jira — Get Transitions",
      "type": "n8n-nodes-base.jira",
      "typeVersion": 1,
      "position": [
        -80,
        480
      ],
      "credentials": {
        "jiraSoftwareCloudApi": {
          "id": "VLcJHetLVoaw3AWA",
          "name": "Jira SW Cloud account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const notionStatus = $('Loop Over Notion Pages').item.json.properties.Status.select.name;\nconst transitions = $input.all();\n\nconst statusMap = {\n  'To Do': ['To Do', 'Open', 'Backlog'],\n  'In Progress': ['In Progress', 'In Development', 'Start Progress'],\n  'Done': ['Done', 'Closed', 'Resolve Issue', 'Mark as Done']\n};\n\nconst targetNames = statusMap[notionStatus] || [notionStatus];\n\nconst match = transitions.find(t =>\n  targetNames.some(name =>\n    t.json.name?.toLowerCase().includes(name.toLowerCase())\n  )\n);\n\nreturn [{\n  json: {\n    transitionId: match ? match.json.id : null,\n    transitionName: match ? match.json.name : null,\n    notionStatus,\n    jiraKey: $('Loop Over Notion Pages').item.json.properties['Jira Key'].rich_text[0].plain_text,\n    priority: $('Loop Over Notion Pages').item.json.properties.Priority.select.name\n  }\n}];"
      },
      "id": "9e2a1355-156e-41bc-89e8-6e942b863803",
      "name": "Map Notion Status → Jira Transition",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        144,
        480
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "condition-has-transition",
              "leftValue": "={{ $json.transitionId }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "24e27d8d-584b-4447-b829-687ae4aa66b9",
